# Data - exclude large/generated files, track reference data and docs
data/raw/
data/logs/
data/reviews/
# Large external reference dumps (reproducible from source; registered in
# meta.reference_sources). Small curated reference (chembl synonyms,
# mesh_ta_mapping) stays tracked.
data/reference/umls/
data/reference/mesh/
data/reference/ror/
# DuckDB file + its write-ahead/temp sidecars (.wal, .tmp/)
data/*.duckdb
data/*.duckdb.*
data/*.zip

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Environment variables
.env
.env.local

# Jupyter
.ipynb_checkpoints/

# R (renv self-ignores its library via renv/.gitignore; these are session cruft)
.Rhistory
.RData
.Rdata
.Rproj.user/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
